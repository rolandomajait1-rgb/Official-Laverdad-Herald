APP_NAME="La Verdad Herald"
APP_ENV=production
APP_KEY=base64:YOUR_GENERATED_KEY_HERE
APP_DEBUG=false
APP_URL=https://official-laverdad-herald.onrender.com
FILESYSTEM_DISK=public

# Database - Render PostgreSQL (auto-injected)
DB_CONNECTION=pgsql
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_DATABASE=${PGDATABASE}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# CORS - UPDATE WITH YOUR ACTUAL FRONTEND URL!
FRONTEND_URL=https://your-actual-frontend-domain.vercel.app

# Mail Configuration - REQUIRED FOR EMAIL VERIFICATION!
MAIL_MAILER=smtp
TRANSACTIONAL_MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_username
MAIL_PASSWORD=your_brevo_smtp_key_here
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS=noreply@laverdadherald.com
MAIL_FROM_NAME="Official La Verdad Herald"
